    "slug": "gp-swimlab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/gpswimlab-logo.png",
    "scheme": "gpswimlab",
    "userInterfaceStyle": "dark",
    "splash": {
