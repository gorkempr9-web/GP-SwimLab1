      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/gpswimlab-logo.png",
        "backgroundColor": "#031B2F"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7f51f0f1-968f-458d-b075-17a38544998d"
      }
    }
