{
  "expo": {
    "name": "SwimLab",
    "slug": "gp-swimlab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/app-icon.png",
    "scheme": "gpswimlab",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/branding/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#071626"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gpswimlab.app"
    },
    "android": {
      "package": "com.gpswimlab.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/app-icon.png",
        "backgroundColor": "#071626"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "enableDemoLogin": true,
      "enableMockOtp": false,
      "allowMockOtp": false,
      "eas": {
        "projectId": "7f51f0f1-968f-458d-b075-17a38544998d"
      }
    }
  }
}
