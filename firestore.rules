rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return signedIn() && request.auth.token.role == 'super_admin';
    }

    function hasClubAccess(clubId) {
      return isSuperAdmin() || (signedIn() && request.auth.token.clubId == clubId);
    }

    function canManageClub(clubId) {
      return isSuperAdmin() || (
        signedIn() &&
        request.auth.token.clubId == clubId &&
        request.auth.token.role in ['coach', 'club_admin']
      );
    }

    match /clubs/{clubId} {
      allow read: if hasClubAccess(clubId);
      allow create, update, delete: if isSuperAdmin() || (
        signedIn() &&
        request.auth.token.clubId == clubId &&
        request.auth.token.role == 'club_admin'
      );

      match /athletes/{athleteId} {
        allow read: if hasClubAccess(clubId);
        allow create, update, delete: if canManageClub(clubId);
      }

      match /coaches/{coachId} {
        allow read: if hasClubAccess(clubId);
        allow create, update, delete: if isSuperAdmin() || (
          signedIn() &&
          request.auth.token.clubId == clubId &&
          request.auth.token.role == 'club_admin'
        );
      }

      match /parents/{parentId} {
        allow read: if hasClubAccess(clubId);
        allow create, update, delete: if canManageClub(clubId);
      }

      match /trainingPlans/{planId} {
        allow read: if hasClubAccess(clubId);
        allow create, update, delete: if canManageClub(clubId);
      }

      match /trainingLog/{entryId} {
        allow read: if hasClubAccess(clubId);
        allow create, update, delete: if canManageClub(clubId);
      }

      match /raceResults/{resultId} {
        allow read: if hasClubAccess(clubId);
        allow create, update, delete: if canManageClub(clubId);
      }

      match /notifications/{notificationId} {
        allow read: if hasClubAccess(clubId);
        allow create, update, delete: if isSuperAdmin() || (
          signedIn() &&
          request.auth.token.clubId == clubId &&
          request.auth.token.role == 'club_admin'
        );
      }
    }

    match /users/{userId} {
      allow read, update: if isSuperAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if signedIn() && request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin() || (
        signedIn() && request.auth.token.role == 'club_admin'
      );
    }
  }
}
