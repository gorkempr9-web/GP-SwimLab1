# GP SwimLab environment template
# Copy this file to .env or .env.local for local development.
# Do not commit real secrets.

# App environment
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_NAME=GP SwimLab
EXPO_PUBLIC_API_BASE_URL=https://api.example.com

# Firebase web/app config placeholders
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Future AI Coach integration
EXPO_PUBLIC_OPENAI_API_KEY=sk-placeholder-do-not-use
